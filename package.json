{
  "name": "node-version-sync",
  "version": "1.0.0",
  "description": "GitHub Action that keeps a repository's declared Node.js versions in sync with the official Node.js release schedule.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "github-action",
    "nodejs",
    "release-schedule",
    "lts",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
